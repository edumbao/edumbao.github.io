      --soft-bg: #0b1020;
      --panel: #111827;
      --panel-2: #151f33;
      --border: #24324a;
      --text: #e0efff;
      --muted: #c4d1e4;
      --muted-2: #9fb0c7;
      --blue: #3b82f6;
