      align-items: center;
      margin-top: 28px;
    }

    .button {
      display: inline-block;
      background: var(--blue);
      color: #ffffff;
      padding: 15px 22px;
      border-radius: 12px;
      font-weight: 700;
      text-decoration: none;
      box-shadow: 0 12px 28px rgba(59, 130, 246, 0.28);
    }

    .button-secondary {
      color: var(--muted);
      text-decoration: none;
      font-size: 15px;
    }

    .mini-note {
      color: var(--muted-2);
      font-size: 14px;
      margin-top: 14px;
    }

    .preview-card {
      background: linear-gradient(180deg, var(--panel), var(--soft-bg));
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
