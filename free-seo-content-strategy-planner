    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    .container {
      max-width: 1080px;
      margin: 0 auto;
      padding: 64px 24px;
    }

    .nav {
